[ctrader]
# Fill in your cTrader Open API credentials here and save as `config.ini`
# Do NOT commit `config.ini` — it's ignored by .gitignore.
CLIENT_ID = YOUR_CLIENT_ID
CLIENT_SECRET = YOUR_CLIENT_SECRET
ACCESS_TOKEN = YOUR_ACCESS_TOKEN
ACCOUNT_ID = 123456

[ai]
# Model type: gb (gradient boosting) or mlp (neural network)
MODEL_TYPE = gb

[llm]
# Optional: enable LLM-based regime detection
enabled = false
backend = ollama  # "ollama" (default) or "lightllm" (faster, GPU recommended)
model = llama3.2
# Only used if backend=lightllm:
lightllm_model_path = /path/to/lightllm/model
